# ─── core ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-python -c "import secrets;print(secrets.token_urlsafe(48))"
DEFAULT_OWNER_EMAIL=owner@marketing-brain.local
DEFAULT_OWNER_PASSWORD=changeme
DEFAULT_ORG_NAME=Racket Sports Group
DEFAULT_MONTHLY_COST_CAP_USD=200

# ─── llm gateway (OpenRouter — all LLMs go through here) ──────────────────────
OPENROUTER_API_KEY=sk-or-v1-REPLACE
OPENROUTER_MODEL_REASONING=anthropic/claude-sonnet-4.5
OPENROUTER_MODEL_DRAFTING=anthropic/claude-haiku-4.5

# ─── media gateway (fal.ai — first provider in the swappable interface) ───────
FAL_KEY=REPLACE

# ─── storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/app/storage
PUBLIC_BASE_URL=http://localhost:8001

# ─── ops ──────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
CORS_ORIGINS=http://localhost:3006,http://localhost:3005,http://localhost:3000

# ─── optional V2 data sources ─────────────────────────────────────────────────
SERPAPI_KEY=
YOUTUBE_API_KEY=
SHOPIFY_WEBHOOK_SECRET=
