# --- Required ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx

# --- Models (any OpenRouter model id) ---
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_IMAGE_MODEL=openai/gpt-image-1

# --- Storage ---
DB_PATH=data/marketing_brain.db
WORKSPACES_ROOT=workspaces/

# --- Optional ---
# PUBLIC_BASE_URL=https://your-app.onrender.com   # needed for IG image publishing
# ADMIN_EMAIL=you@example.com                      # auto-creates an admin on boot
# ADMIN_PASSWORD=change-me
